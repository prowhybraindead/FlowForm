PORT=25534
UPLOAD_DIR=./data/uploads
METADATA_DB_PATH=./data/metadata.db
MAX_UPLOAD_MB=10
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp,gif
ALLOW_ORIGINS=*
UPLOAD_TOKEN=
PUBLIC_BASE_URL=
MAX_FILES_PER_FORM=5000
MAX_BYTES_PER_FORM=5368709120
COMPRESS_AFTER_DAYS=7
COMPRESSION_INTERVAL_SECONDS=3600
COMPRESSION_BATCH_SIZE=100
COMPRESSION_MIN_SAVINGS_BYTES=4096
JPEG_QUALITY=72
WEBP_QUALITY=70
CLOSED_FORM_IDS=

# Optional Cloudflare Tunnel runtime flags
USE_CLOUDFLARE_TUNNEL=0
TUNNEL_REQUIRED=0
TUNNEL_CONFIG_PATH=./cloudflared/config.yml
TUNNEL_METRICS=127.0.0.1:60123
CLOUDFLARE_TUNNEL_TOKEN=
TUNNEL_FAIL_ON_EXIT=0
TUNNEL_LOG_LEVEL=info
TUNNEL_PROTOCOL=auto
TUNNEL_AUTO_INSTALL_CLOUDFLARED=1
CLOUDFLARED_BIN_PATH=./.cloudflared/bin/cloudflared
    
