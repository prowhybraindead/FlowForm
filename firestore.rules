rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(ownerId) { return isSignedIn() && request.auth.uid == ownerId; }

    // Validation Blueprints
    function isValidForm(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.creatorId is string && data.creatorId == request.auth.uid &&
             data.createdAt is number && data.updatedAt is number &&
             data.questions is list && data.questions.size() <= 100;
    }

    function isValidResponse(data) {
      return data.formId is string && data.formId.size() <= 128 &&
             data.submittedAt is number &&
             data.answers is map;
    }

    // Forms Collection
    match /forms/{formId} {
      allow get: if true; // Public can view form meta to respond
      allow list: if isSignedIn(); // Logged in users can see list (we will filter in queries)
      
      allow create: if isSignedIn() && isValidId(formId) && isValidForm(incoming());
      
      allow update: if isSignedIn() && isOwner(existing().creatorId) && 
                      isValidForm(incoming()) &&
                      incoming().creatorId == existing().creatorId &&
                      incoming().createdAt == existing().createdAt;
                      
      allow delete: if isSignedIn() && isOwner(existing().creatorId);

      // Responses subcollection
      match /responses/{responseId} {
        allow create: if true; // Anyone can submit a response (public forms)
        allow read: if isSignedIn() && isOwner(get(/databases/$(database)/documents/forms/$(formId)).data.creatorId);
      }
    }
  }
}
